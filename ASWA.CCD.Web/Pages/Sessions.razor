@page "/sessions"

@inject HttpClient http

<PageTitle>Sessions</PageTitle>

<h1 class="page-title">Sessions</h1>
<p class="page-subtitle">Browse the bootcamp schedule</p>

@if (sessions == null)
{
    if (message != null)
    {
        <div class="error-state">
            <h2>@message</h2>
        </div>
    }
    else
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>Loading sessions...</p>
        </div>
    }
}
else
{
    <div class="session-grid">
        @{ var delay = 0; }
        @foreach (var session in sessions)
        {
            <div class="session-card fade-in fade-in-delay-@(delay % 4) @(session.IsPast ? "session-past" : "") @(session.IsActive ? "session-active" : "")">
                <h3>@session.Title</h3>
                <div class="session-meta">
                    <span class="meta-tag">🕐 @session.Start – @session.End</span>
                    <span class="meta-tag">📍 @session.Room</span>
                </div>
                <a class="details-link" href="/sessiondetails/20260610/@(session.Id)">View details →</a>
            </div>
            delay++;
        }
    </div>
}

@code {
    private SessionModel[]? sessions;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        message = null;
        try
        {
            sessions = await http.GetFromJsonAsync<SessionModel[]>("/api/sessions");
        }
        catch
        {
            message = "Something went wrong trying to get our sessions. Please try again.";
        }
    }
}
