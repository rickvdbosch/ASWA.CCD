@page "/sessiondetails/{day}/{id}"

@inject HttpClient http

<PageTitle>Session Details</PageTitle>

<a class="back-link" href="/sessions">← Back to sessions</a>

@if (session == null)
{
    if (message != null)
    {
        <div class="error-state">
            <h2>@message</h2>
        </div>
    }
    else
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>Loading session details...</p>
        </div>
    }
}
else
{
    <div class="detail-card">
        <h1>@session.Title</h1>
        <div class="speaker-name">@((MarkupString)session.Speaker)</div>
        <div class="description">
            @session.Description
        </div>
    </div>
}

@code {
    [Parameter] public string? day { get; set; }
    [Parameter] public string? id { get; set; }

    private SessionModel? session;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        message = null;
        try
        {
            session = await http.GetFromJsonAsync<SessionModel>($"/api/sessions/{day}/{id}");
        }
        catch
        {
            message = "Something went wrong trying to get this session. Please try again.";
        }
    }
}
